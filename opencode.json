{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "xcodebuild": {
      "type": "local",
      "command": ["/opt/homebrew/bin/xcodebuildmcp", "mcp"],
      "enabled": true
    },
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    }
  }
}
